{
    "name": "felipemateus/iptv-cms",
    "type": "project",
    "description": "This is a cms control iptv channels.",
    "authors": [
        {
            "name": "Felipe Mateus",
            "email": "eu@felipemateus.com",
            "homepage": "https://felipemateus.com",
            "role": "Developer"
        }
    ],
    "keywords": ["framework", "laravel",
        "Laravel",
        "IPTV",
        "IPTVCHannels",
        "Channels",
        "iptv-channels",
        "channels-m3u8",
        "channels-list",
        "iptv-laravel",
        "m3u8-iptv",
        "channel",
        "Playlist",
        "iptv-playlist",
        "m3u8",
        "laravel-package",
        "customers",
        "iptv-customer",
        "iptv-url",
        "iptv-brasil",
        "canais"
],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "microweber-deps/laravel-cors": "^3.1",
        "guzzlehttp/guzzle": "^7.5",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^v4.0",
        "laravel/tinker": "^2.9",
        "felipemateus/http-build-url": "^0.0.1"
    },
    "require-dev": {
        "spatie/laravel-ignition": "^2.7",
        "fakerphp/faker": "^1.23",
        "laravel/sail": "^1.26",
        "laravel/pint": "^1.21",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
